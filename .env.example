# Base URL for QR code generation
# BASE_URL=http://localhost:8000

# Video quality (360, 480, 720, 1080)
# VIDEO_QUALITY=1080

# Allow users to add multiple videos to queue
# ALLOW_MULTIPLE_VIDEOS=false

# Lock the multi-add toggle so users can't change it
# MULTIPLE_VIDEOS_LOCKED=false

# Enable auto-queue from same artist when queue is empty
# AUTO_QUEUE_ENABLED=true

# Lock the auto-queue toggle so users can't change it
# AUTO_QUEUE_LOCKED=false

# Path to logo image
# LOGO_PATH=/static/logo/logo.png

# Maximum video duration in seconds (0 = no limit)
# MAX_DURATION_SECONDS=600
